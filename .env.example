# Copy to .env. Only needed if llm.provider is "anthropic" or "openai".
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# Spotify Web API (optional) — enables play-by-name, volume, and now-playing.
# Create an app at https://developer.spotify.com/dashboard and add the redirect
# URI  http://127.0.0.1:8765/spotify/callback  to it. Then say "connect Spotify".
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
